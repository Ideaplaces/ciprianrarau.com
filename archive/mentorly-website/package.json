  "scripts": {
    "analyze": "ANALYZE=true next build",
    "build-storybook": "build-storybook",
    "build": "next build --debug",
    "build:debug": "next build --debug",
    "check-types": "tsc --noemit",
    "cypress:open": "cypress open",
    "dev": "concurrently \"npm run server\" \"npm run graphql-codegen\"",
    "dev:local": "concurrently \"npm run server:local\" \"npm run graphql-codegen:local\"",
    "server:local": "NEXT_PUBLIC_API_URL=http://localhost:3000 next dev -H 127.0.0.1 -p 3010",
    "server:production": "NEXT_PUBLIC_API_URL=https://api.mentorly.com next dev -H 127.0.0.1 -p 3010",
    "server:staging": "NEXT_PUBLIC_API_URL=https://api2.mentorly.co next dev -H 127.0.0.1 -p 3010",
    "server": "next dev -H 127.0.0.1 -p 3010",
    "format": "prettier --write './**/*.{js,jsx,ts,tsx,css,md,json}' --config ./.prettierrc",
    "graphql-codegen": "graphql-codegen --config codegen.yml --watch",
    "graphql-codegen:local": "SCHEMA_PATH=http://localhost:3000/graphql graphql-codegen --config codegen.yml --watch",
    "graphql:generate": "graphql-cli generate",
    "graphql:sync": "./scripts/graphql-sync.sh",
    "graphql:check": "./scripts/graphql-sync.sh --check",
    "graphql:types": "./scripts/graphql-sync.sh --types",
    "graphql:watch": "./scripts/graphql-sync.sh --watch",
    "lint:fix": "eslint . --fix",
    "lint": "eslint .",
    "next:lint": "next lint",
    "start": "next start",
    "storybook": "start-storybook -p 6006",
    "superlinter": "docker run -e JAVASCRIPT_ES_CONFIG_FILE=.eslintrc.js -e JAVASCRIPT_DEFAULT_STYLE=prettier -e LINTER_RULES_PATH=/ -e VALIDATE_JAVASCRIPT_ES=true -e VALIDATE_JAVASCRIPT_PRETTIER=true -e RUN_LOCAL=true -v ${PWD}:/tmp/lint github/super-linter",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci --coverage=true",
    "test": "jest",
    "process-mermaid": "node scripts/process-mermaid-diagrams.js"
  },
