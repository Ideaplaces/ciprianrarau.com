---
import Layout from '~/layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
import { getPermalink } from '~/utils/permalinks';

const metadata = {
  title: 'CV - Ciprian (Chip) Rarau | Entrepreneur, System Architect, CTO',
  description: 'Professional CV of Ciprian Rarau - 25+ years of experience in technology leadership, system architecture, and entrepreneurship',
};
---

<Layout metadata={metadata}>
  <div class="cv-wrapper min-h-screen bg-white">
    <!-- Print/Download Buttons - Hidden in print -->
    <div class="flex justify-end gap-3 p-4 no-print">
      <button onclick="window.print()" class="flex items-center gap-2 px-4 py-2 bg-cyan-600 text-white rounded-lg hover:bg-cyan-700 transition-colors shadow-md">
        <Icon name="tabler:printer" class="w-5 h-5" />
        Print
      </button>
      <a href="/api/cv-pdf" download="Ciprian_Rarau_CV.html" class="flex items-center gap-2 px-4 py-2 bg-cyan-600 text-white rounded-lg hover:bg-cyan-700 transition-colors shadow-md">
        <Icon name="tabler:download" class="w-5 h-5" />
        Download HTML
      </a>
    </div>

    <div class="cv-container mx-auto bg-white" style="max-width: 850px;">
      <!-- Header Section with colored background -->
      <header class="cv-header">
        <div class="header-content">
          <div class="profile-section">
            <img src="/images/profile-chip.jpg" alt="Ciprian Rarau" class="profile-photo" />
            <div class="name-section">
              <h1 class="name">Ciprian (Chip) Rarau</h1>
              <h2 class="tagline">Entrepreneur & Founder & CTO & CPO</h2>
            </div>
          </div>
          
          <div class="contact-grid">
            <a href="mailto:chip@ciprianrarau.com" class="contact-item">
              <Icon name="tabler:mail" class="contact-icon" />
              chip@ciprianrarau.com
            </a>
            <a href="tel:+15145605016" class="contact-item">
              <Icon name="tabler:phone" class="contact-icon" />
              514-560-5016
            </a>
            <a href="https://ciprianrarau.com" target="_blank" class="contact-item">
              <Icon name="tabler:world" class="contact-icon" />
              ciprianrarau.com
            </a>
            <a href="https://linkedin.com/in/ciprianrarau" target="_blank" class="contact-item">
              <Icon name="tabler:brand-linkedin" class="contact-icon" />
              linkedin.com/in/ciprianrarau
            </a>
            <a href="https://github.com/crarau" target="_blank" class="contact-item">
              <Icon name="tabler:brand-github" class="contact-icon" />
              github.com/crarau
            </a>
            <a href="https://cal.com/chip-tech/45min" target="_blank" class="contact-item">
              <Icon name="tabler:calendar" class="contact-icon" />
              Schedule a meeting
            </a>
          </div>
        </div>
      </header>

      <!-- Main Content -->
      <main class="main-content">
        <!-- Career Profile -->
        <section class="content-section">
          <h2 class="section-title">
            <Icon name="tabler:user" class="section-icon" />
            CAREER PROFILE
          </h2>
          <div class="profile-content">
            <p>
              I am an entrepreneur and technologist with a deep passion for the intersection of software and business. 
              I'm a systems thinker who thrives on building innovative technology solutions that create real value. 
              My expertise spans the entire technology stack - from infrastructure and architecture to product development and business strategy.
            </p>
            <p class="mt-3">
              I have a proven track record of building businesses from scratch:
            </p>
            <ul class="achievements-list">
              <li><strong>WISK.ai (Co-Founder/CTO/CPO)</strong> - Built and scaled from 0 to 1,000 customers, bootstrapped then raised $3 million and achieved profitability. I was also an early investor.</li>
              <li><strong>At OMsignal (CTO & 1st employee)</strong> (acquired by Honeywell), I helped raise $10 million.</li>
              <li><strong>IdeaPlaces (Solo Founder)</strong>, which integrated with Evernote, Dropbox, and Photos, creating pins on the map for these. The app achieved 25,000 downloads, had significant business traction, and was featured by Evernote in their ecosystem.</li>
              <li>Additionally, I have served as a <strong>fractional CTO for 5 venture-backed businesses</strong>.</li>
            </ul>
            <p class="mt-3">
              Throughout my career, I have demonstrated my ability to transform initial ideas into successful, commercialized ventures. I have successfully raised multiple rounds of financing from seed to Series A and navigated complex challenges, including the Covid-19 pandemic. My hands-on leadership style has allowed me to contribute directly to key areas such as DevOps, backend, data architecture, data pipeline, data analytics, frontend, and mobile development.
            </p>
            <p class="mt-3">
              I take pride in inspiring and motivating teams to achieve outstanding results by fostering a culture of trust, transparency, and continuous improvement. My core values of connection, kindness, gratitude, curiosity, courage, empowerment, honesty, and love drive my passion for innovation and my commitment to building successful companies.
            </p>
            <p class="mt-3">
              I am currently leveraging my extensive experience to drive new innovations at the intersection of AI, technology, and business. 
              I'm passionate about working on transformative projects that push boundaries and create meaningful impact. 
              Whether it's building from scratch, scaling existing platforms, or advising on technical strategy, I bring a unique blend of technical depth and business acumen.
            </p>
          </div>
        </section>

        <!-- Two Column Layout for Skills and Education -->
        <div class="two-column-grid">
          <!-- Technical Skills -->
          <section class="content-section">
            <h2 class="section-title">
              <Icon name="tabler:code" class="section-icon" />
              TECHNICAL SKILLS
            </h2>
            <div class="skills-content">
              <div class="skill-category">
                <h4 class="skill-title">Languages & Frameworks</h4>
                <p class="skill-list">
                  Python, TypeScript, JavaScript, Ruby, Java, Kotlin, Swift, PHP, Go • 
                  React, Vue.js, Angular, Next.js • 
                  Node.js, Django, Flask, Rails, Laravel • 
                  React Native, Flutter, Ionic
                </p>
              </div>
              <div class="skill-category">
                <h4 class="skill-title">Infrastructure & DevOps</h4>
                <p class="skill-list">
                  GCP, AWS, Terraform, Ansible • 
                  Docker, Kubernetes, Jenkins • 
                  PostgreSQL, MySQL, MongoDB, Redis • 
                  BigQuery, Elasticsearch
                </p>
              </div>
              <div class="skill-category">
                <h4 class="skill-title">Specializations</h4>
                <p class="skill-list">
                  AI/ML Integration, LLMs, Microservices Architecture, Real-time Systems, 
                  Mobile Development, Data Analytics, Marketing Automation
                </p>
              </div>
            </div>
          </section>

          <!-- Education, Languages & Interests -->
          <section class="content-section">
            <h2 class="section-title">
              <Icon name="tabler:school" class="section-icon" />
              EDUCATION
            </h2>
            <div class="education-content">
              <div class="education-item">
                <h4 class="degree">Bachelor in Computer Science Engineering</h4>
                <p class="institution">Technical University of Cluj-Napoca, Romania</p>
                <p class="education-date">1998 - 2003</p>
              </div>
              <div class="education-item">
                <h4 class="degree">Computer Science</h4>
                <p class="institution">High School of Computer Science, Tiberiu Popoviciu</p>
                <p class="education-date">1994 - 1998</p>
              </div>
            </div>

            <h2 class="section-title mt-6">
              <Icon name="tabler:language" class="section-icon" />
              LANGUAGES
            </h2>
            <div class="languages-content">
              <span class="language-item">English (Professional)</span> • 
              <span class="language-item">French (Professional)</span> • 
              <span class="language-item">Romanian (Native)</span>
            </div>

            <h2 class="section-title mt-6">
              <Icon name="tabler:star" class="section-icon" />
              INTERESTS
            </h2>
            <div class="interests-content">
              AI & Large Language Models • System Architecture • Business Process Optimization • 
              Yoga & Meditation • Psychology • Nature
            </div>
          </section>
        </div>

        <!-- Professional Experience -->
        <section class="content-section">
          <h2 class="section-title">
            <Icon name="tabler:briefcase" class="section-icon" />
            PROFESSIONAL EXPERIENCE
          </h2>

          <!-- Current Roles -->
          <div class="job-entry">
            <div class="job-header">
              <div>
                <h3 class="job-title">CTO/CPO</h3>
                <div class="job-company">
                  <a href="https://mentorly.com" target="_blank" class="company-link">Mentorly</a>, Remote
                </div>
              </div>
              <span class="job-date">Jan 2025 - Present</span>
            </div>
            <div class="job-description">
              <p>
                I lead all things tech at Mentorly, a mentorship platform helping enterprises circulate knowledge internally. 
                I manage the platform end to end—backend, infrastructure, AI systems, and internal tools—while staying hands-on in product, sales, and marketing. 
                From sentiment analysis to LLM-powered mentor matching, I bring speed and stability to a growing system that's delivering real value. 
                I don't just build the tech—I help drive the business.
              </p>
              <div class="tech-stack">
                <strong>Key technologies:</strong> Python, TypeScript, AI/LLMs, Cloud Infrastructure, Sentiment Analysis
              </div>
            </div>
          </div>

          <div class="job-entry">
            <div class="job-header">
              <div>
                <h3 class="job-title">Technical Advisor</h3>
                <div class="job-company">
                  <a href="https://eli.health" target="_blank" class="company-link">Eli Health</a>, Remote
                </div>
              </div>
              <span class="job-date">Apr 2025 - Present</span>
            </div>
            <div class="job-description">
              <p>
                Leading the tech strategy and execution at Eli, a fast-paced health tech startup measuring hormonal biomarkers like cortisol and progesterone. 
                I architect and maintain the mobile backend infrastructure, ensuring secure handling of personal health data. 
                My role spans product development, hands-on coding, cross-functional leadership, and rapid iteration cycles.
              </p>
            </div>
          </div>

          <div class="job-entry">
            <div class="job-header">
              <div>
                <h3 class="job-title">Co-Founder</h3>
                <div class="job-company">
                  <a href="https://wehappers.org" target="_blank" class="company-link">WeHappers.org</a> - non profit
                </div>
              </div>
              <span class="job-date">Jan 2024 - Present</span>
            </div>
            <div class="job-description">
              <p>
                Our mission is to reshape wealth distribution to spark global happiness by combining investment and intelligence on tech initiatives 
                that enable wealth sharing and provide a happiness experience.
              </p>
              <ul class="job-achievements">
                <li>Focused on efficient engineering, incubating positive initiatives, and platform building for NPOs.</li>
                <li>Measuring and positively impacting the level of happiness through our projects.</li>
              </ul>
            </div>
          </div>

          <div class="job-entry">
            <div class="job-header">
              <div>
                <h3 class="job-title">Venture Developer, Co-Founder</h3>
                <div class="job-company">
                  <a href="https://catalyzeup.ai" target="_blank" class="company-link">CatalyzeUp</a>, Montreal, Canada Area
                </div>
              </div>
              <span class="job-date">2017 - Present</span>
            </div>
            <div class="job-description">
              <p>
                Helping and sharing knowledge with fellow entrepreneurs in the tech/product building space. 
                Partnering with early adopter founders to validate and scale their startups.
              </p>
              <p><strong>Portfolio companies:</strong> Alvéole, XpertSea, PBSC (acquired by Lyft), Mentorly, ENDVR.io</p>
              <p>
                Giving back to the Montreal ecosystem by making friends and helping grow the community through hands-on development and evangelizing venture development.
              </p>
            </div>
          </div>

          <!-- Past Experience -->
          <div class="job-entry">
            <div class="job-header">
              <div>
                <h3 class="job-title">CTO/CPO, Co-Founder</h3>
                <div class="job-company">
                  <a href="https://wisk.ai" target="_blank" class="company-link">WISK.ai</a>, Founded in Montreal, Canada → Remote
                </div>
              </div>
              <span class="job-date">2016 - Jan 2025</span>
            </div>
            <div class="job-description">
              <p>
                I built the product, scaled the development team to 10 members, and grew the business to over 1,000 clients. 
                With over 100 PostgreSQL tables, a native mobile app, VueJS, and a robust backend infrastructure as code, 
                I methodically grew the product step by step while beating the competition with a fraction of the spend. 
                Raised around $3 million and got the business to profitability.
              </p>
              <ul class="job-achievements">
                <li>Built the platform from the ground up using best-of-breed architectures and technologies.</li>
                <li>Led the team in developing a micro-services architecture that supports offline and real-time operations.</li>
                <li>Involved in finance, partnerships, support and all aspects of the business.</li>
              </ul>
              <div class="tech-stack">
                <strong>Key technologies:</strong> Swift, Kotlin, Native Mobile, PHP, VueJS, NodeJS, DevOps, GCP, Terraform, Ansible, Superset, Microservices
              </div>
            </div>
          </div>

          <div class="job-entry">
            <div class="job-header">
              <div>
                <h3 class="job-title">Fractional CTO</h3>
                <div class="job-company">
                  <a href="https://alveole.buzz" target="_blank" class="company-link">Alvéole</a>, Montreal, Quebec, Canada
                </div>
              </div>
              <span class="job-date">Jan 2023 - May 2024</span>
            </div>
            <div class="job-description">
              <p>
                Providing strategic advice and support to help Alvéole scale and grow its operations. 
                Built the foundations for their NextGen platform from scratch, involving DevOps, GCP, backoffice, 
                and web using TypeScript, MongoDB, and GraphQL with a microservices architecture. Also hired for the development team.
              </p>
            </div>
          </div>

          <div class="job-entry">
            <div class="job-header">
              <div>
                <h3 class="job-title">Fractional CTO</h3>
                <div class="job-company">
                  <a href="https://xpertsea.com" target="_blank" class="company-link">XpertSea</a>, Quebec, Canada
                </div>
              </div>
              <span class="job-date">Dec 2021 - Jan 2024</span>
            </div>
            <div class="job-description">
              <p>
                Assured the transition of technical leadership, hired the full-time CTO, and supported the existing team on key deliverables.
              </p>
              <div class="tech-stack">
                <strong>Key technologies:</strong> AWS, NodeJS, Python, Ansible, Terraform, TypeScript/JavaScript, React JS/Native, Gitlab/GitHub
              </div>
            </div>
          </div>

          <!-- Earlier Experience Summary -->
          <div class="job-entry earlier-experience">
            <h3 class="job-title">Earlier Experience</h3>
            <div class="earlier-list">
              <div class="earlier-item">
                <strong>Head of Mobile</strong> at Eastern Bank <span class="job-date-inline">(2015 - 2016)</span>
                <p>Led mobile development for banking app. Passed PWC full security audit.</p>
              </div>
              <div class="earlier-item">
                <strong>Solo Founder</strong> at IdeaPlaces <span class="job-date-inline">(2014 - 2016)</span>
                <p>Location-based app for Evernote & Dropbox. Featured by Evernote, 25,000+ downloads.</p>
              </div>
              <div class="earlier-item">
                <strong>VP Engineering</strong> at OMsignal (acquired by Honeywell) <span class="job-date-inline">(2012 - 2014)</span>
                <p>Built wearable device software stack. Raised $10M+ and secured Ralph Lauren partnership.</p>
              </div>
              <div class="earlier-item">
                <strong>Lead R&D</strong> at Aptilon <span class="job-date-inline">(2010 - 2012)</span>
                <p>Led technical decisions and improved team efficiency.</p>
              </div>
              <div class="earlier-item">
                <strong>Senior Java Developer</strong> at Coradiant (Acquired by BMC) <span class="job-date-inline">(2006 - 2010)</span>
                <p>Evangelized Test Driven Development and Agile. Presented at Microstrategy World.</p>
              </div>
              <div class="earlier-item">
                <strong>Team Lead & Java Developer</strong> at Gestion Resources <span class="job-date-inline">(2004 - 2006)</span>
                <p>Built complete bookstore management system.</p>
              </div>
              <div class="earlier-item">
                <strong>Developer</strong> at Nethrom <span class="job-date-inline">(2000 - 2004)</span>
                <p>Delivered 10+ projects using diverse technologies.</p>
              </div>
            </div>
          </div>
        </section>
      </main>
    </div>
  </div>

  <style>
    /* Base Styles */
    .cv-wrapper {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
      color: #333;
      line-height: 1.6;
      font-size: 15px;
    }

    .cv-container {
      box-shadow: 0 0 20px rgba(0, 0, 0, 0.1);
      background: white;
    }

    /* Header Styles */
    .cv-header {
      background: #0891B2;
      color: white;
      padding: 40px 50px 30px;
      page-break-inside: avoid;
      break-inside: avoid;
    }

    .header-content {
      max-width: 100%;
      page-break-inside: avoid;
      break-inside: avoid;
    }

    .profile-section {
      display: flex;
      align-items: center;
      gap: 30px;
      margin-bottom: 25px;
      page-break-inside: avoid;
      break-inside: avoid;
    }

    .profile-photo {
      width: 120px;
      height: 120px;
      border-radius: 50%;
      border: 4px solid rgba(255, 255, 255, 0.3);
      object-fit: cover;
    }

    .name-section {
      flex: 1;
      page-break-inside: avoid;
      break-inside: avoid;
    }

    .name {
      font-size: 36px;
      font-weight: 700;
      margin-bottom: 5px;
      line-height: 1.2;
    }

    .tagline {
      font-size: 18px;
      opacity: 0.95;
      font-weight: 400;
    }

    .contact-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 10px 30px;
      page-break-inside: avoid;
      break-inside: avoid;
    }

    .contact-item {
      display: flex;
      align-items: center;
      gap: 8px;
      color: white;
      text-decoration: none;
      font-size: 14px;
      opacity: 0.95;
      transition: opacity 0.2s;
    }

    .contact-item:hover {
      opacity: 1;
    }

    .contact-icon {
      width: 16px;
      height: 16px;
      flex-shrink: 0;
    }

    /* Main Content */
    .main-content {
      padding: 40px 50px;
    }

    .content-section {
      margin-bottom: 35px;
    }

    .section-title {
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 18px;
      font-weight: 700;
      color: #2D3748;
      margin-bottom: 20px;
      padding-bottom: 8px;
      border-bottom: 2px solid #E2E8F0;
    }

    .section-icon {
      width: 20px;
      height: 20px;
      color: #0891B2;
    }

    /* Career Profile */
    .profile-content {
      color: #4A5568;
      text-align: justify;
    }

    .profile-content p {
      margin-bottom: 12px;
    }

    .achievements-list {
      margin: 15px 0;
      padding-left: 25px;
    }

    .achievements-list li {
      margin-bottom: 8px;
      list-style: disc;
      color: #4A5568;
    }

    /* Two Column Grid */
    .two-column-grid {
      display: grid;
      grid-template-columns: 1.5fr 1fr;
      gap: 40px;
      margin-bottom: 35px;
    }

    /* Skills */
    .skill-category {
      margin-bottom: 15px;
    }

    .skill-title {
      font-size: 14px;
      font-weight: 600;
      color: #2D3748;
      margin-bottom: 5px;
    }

    .skill-list {
      font-size: 13px;
      color: #4A5568;
      line-height: 1.5;
    }

    /* Education */
    .education-item {
      margin-bottom: 15px;
    }

    .degree {
      font-size: 14px;
      font-weight: 600;
      color: #2D3748;
      margin-bottom: 2px;
    }

    .institution {
      font-size: 13px;
      color: #4A5568;
      margin-bottom: 2px;
    }

    .education-date {
      font-size: 12px;
      color: #718096;
    }

    /* Languages & Interests */
    .languages-content,
    .interests-content {
      font-size: 14px;
      color: #4A5568;
    }

    .language-item {
      font-weight: 500;
    }

    /* Experience */
    .job-entry {
      margin-bottom: 30px;
      padding-bottom: 25px;
      border-bottom: 1px solid #E2E8F0;
    }

    .job-entry:last-child {
      border-bottom: none;
      margin-bottom: 0;
      padding-bottom: 0;
    }

    .job-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 10px;
    }

    .job-title {
      font-size: 17px;
      font-weight: 600;
      color: #1A202C;
      margin-bottom: 3px;
    }

    .job-company {
      font-size: 14px;
      color: #0891B2;
    }

    .company-link {
      color: #0891B2;
      text-decoration: none;
    }

    .company-link:hover {
      text-decoration: underline;
    }

    .job-date {
      font-size: 13px;
      color: #718096;
      white-space: nowrap;
      flex-shrink: 0;
    }

    .job-description {
      color: #4A5568;
    }

    .job-description p {
      margin-bottom: 10px;
      text-align: justify;
    }

    .job-achievements {
      margin: 10px 0;
      padding-left: 25px;
    }

    .job-achievements li {
      margin-bottom: 6px;
      list-style: disc;
      font-size: 14px;
    }

    .tech-stack {
      margin-top: 10px;
      font-size: 13px;
      color: #718096;
    }

    /* Earlier Experience */
    .earlier-experience {
      background: #F7FAFC;
      padding: 20px;
      border-radius: 8px;
    }

    .earlier-list {
      margin-top: 15px;
    }

    .earlier-item {
      margin-bottom: 12px;
      padding-bottom: 12px;
      border-bottom: 1px solid #E2E8F0;
    }

    .earlier-item:last-child {
      border-bottom: none;
      margin-bottom: 0;
      padding-bottom: 0;
    }

    .earlier-item p {
      font-size: 13px;
      color: #718096;
      margin-top: 3px;
    }

    .job-date-inline {
      font-size: 12px;
      color: #A0AEC0;
    }

    /* Print Styles */
    @media print {
      @page {
        size: letter;
        margin: 0.5in;
      }

      body {
        margin: 0;
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
      }

      .no-print {
        display: none !important;
      }

      .cv-wrapper {
        background: white;
      }

      .cv-container {
        max-width: 100% !important;
        margin: 0 !important;
        box-shadow: none !important;
      }

      .cv-header {
        background: #0891B2 !important;
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
        padding: 30px 40px 25px;
        page-break-after: avoid;
        page-break-inside: avoid !important;
        break-inside: avoid !important;
        position: relative;
        overflow: visible;
      }

      .header-content {
        page-break-inside: avoid !important;
        break-inside: avoid !important;
      }

      .profile-section {
        page-break-inside: avoid !important;
        break-inside: avoid !important;
      }

      .main-content {
        padding: 30px 40px;
      }

      .name {
        font-size: 28px;
      }

      .tagline {
        font-size: 16px;
      }

      .contact-grid {
        page-break-inside: avoid !important;
        break-inside: avoid !important;
        display: grid !important;
      }

      .profile-photo {
        width: 100px;
        height: 100px;
      }

      .section-title {
        font-size: 14px;
        page-break-after: avoid;
        margin-bottom: 15px;
      }

      .job-entry {
        page-break-inside: avoid;
        margin-bottom: 20px;
        padding-bottom: 18px;
      }

      .two-column-grid {
        page-break-inside: avoid;
      }

      /* Ensure sections don't break */
      section {
        page-break-inside: avoid;
      }

      /* Hide navigation and footer */
